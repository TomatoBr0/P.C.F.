{
  "manifest_version": 3,
  "name": "PC Fast",
  "version": "1.1",
  "description": "PC Fast - Automatically completes Concept Builder tasks.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.fliplt.com/*",
        "*://*.conceptbuilder.org/*",
        "https://*.physicscentral.com/*",
        "<all_urls>"
      ],
      "js": [
        "console.js",
        "content.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "assets/icon128.png"
  }
}